#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<EOF
Usage: $(basename "$0") <youtube_url | file_with_urls>

Downloads YouTube transcripts/subtitles and converts them to plain text.

Arguments:
  <youtube_url>       A direct link to a YouTube video or playlist.
  <file_with_urls>    A text file containing one YouTube URL per line.
                      Lines starting with '#' are ignored.

Environment Variables:
  OUTDIR              Directory where transcripts will be saved.
                      Default: \$(pwd)/transcripts
  ARCHIVE             Path to the download archive file to avoid re-downloads.
                      Default: \$OUTDIR/archive.txt
  SUB_LANG            Language tag to download (e.g. 'en', 'it').
                      Default: Your current locale language (\${LANG})

Output Structure:
  \$OUTDIR/<Uploader>/<Title>.txt

Examples:
  $(basename "$0") "https://www.youtube.com/watch?v=dQw4w9WgXcQ"
  SUB_LANG=en $(basename "$0") playlist_urls.txt
EOF
  exit 0
}

if [[ $# -lt 1 ]] || [[ "$1" == "-h" ]] || [[ "$1" == "--help" ]]; then
  usage
fi

INPUT="$1"
DEFAULT_LOCALE_LANG="${LANG:-en}"
DEFAULT_LOCALE_LANG="${DEFAULT_LOCALE_LANG%%_*}"
DEFAULT_LOCALE_LANG="${DEFAULT_LOCALE_LANG%%.*}"
SUB_LANG="${SUB_LANG:-$DEFAULT_LOCALE_LANG}"
OUTDIR="${OUTDIR:-$(pwd)/transcripts}"
ARCHIVE="${ARCHIVE:-$OUTDIR/archive.txt}"
TMPDIR="$(mktemp -d)"

mkdir -p "$OUTDIR"

cleanup() { rm -rf "$TMPDIR"; }
trap cleanup EXIT

download_subs() {
  local url="$1"

  yt-dlp --cookies-from-browser safari \
    --ignore-errors \
    --skip-download \
    --download-archive "$ARCHIVE" \
    --write-info-json \
    --write-subs \
    --write-auto-subs \
    --sub-lang "$SUB_LANG" \
    --sub-format vtt \
    --output "$TMPDIR/%(id)s.%(ext)s" \
    "$url" || true
}

vtt_to_txt() {
  local vtt="$1"
  local fname id lang infojson title uploader upload_date safe out_dir out

  fname="$(basename "$vtt")"

  # Extract YouTube video id
  id="${fname%%.*}"

  infojson="$TMPDIR/${id}.info.json"

  # Read metadata from infojson
  IFS='|' read -r uploader upload_date title <<EOF
$(python3 - "$infojson" <<'PY'
import sys, json, pathlib
p = pathlib.Path(sys.argv[1])
if p.exists():
    try:
        d = json.loads(p.read_text(encoding='utf-8', errors='replace'))
        print(f"{d.get('uploader', 'Unknown')}|{d.get('upload_date', '00000000')}|{d.get('title') or d.get('fulltitle') or ''}")
    except Exception:
        print("Unknown|00000000|")
else:
    print("Unknown|00000000|")
PY
)
EOF

  # Sanitize title for macOS filenames.
  safe="$(python3 - "$id" "$title" <<'PY'
import sys, re
id = sys.argv[1]
title = sys.argv[2]
s = title or id
s = s.replace('/', '-').replace('\\', '-').replace(':', ' - ')
s = re.sub(r"\s+", " ", s).strip()
s = re.sub(r"[\000-\037]", "", s)
s = s[:200].rstrip()
print(s)
PY
 )"

  if [[ -n "$safe" ]]; then
    out="$OUTDIR/${safe}.txt"
  else
    out="$OUTDIR/${id}.txt"
  fi

  awk -f - "$vtt" > "$out" <<'AWK'
function trim(s){ sub(/^[ \t]+/, "", s); sub(/[ \t]+$/, "", s); return s }
BEGIN { in_header=1; prev="" }

{ sub(/\r$/, "", $0) }

in_header {
  if ($0=="") in_header=0
  next
}

/^WEBVTT/ { next }
/^Kind: / { next }
/^Language: / { next }
/^NOTE/ { next }
/^STYLE/ { next }
/^REGION/ { next }

/^[0-9]+$/ { next }
/^[0-9]{2}:[0-9]{2}:[0-9]{2}\.[0-9]{3} --> / { next }
/^[0-9]{1,2}:[0-9]{2}\.[0-9]{3} --> / { next }

$0=="" { next }

{
  # Strip tags
  gsub(/<[^>]+>/, "", $0)

  # Decode/clean common HTML entities (cheap but effective)
  gsub(/&nbsp;|&#160;/, " ", $0)
  gsub(/&amp;/, "&", $0)
  gsub(/&quot;/, "\"", $0)
  gsub(/&#39;/, "'", $0)

  line = trim($0)
  if (line=="") next

  # Remove non-speech markers at the start; keep remaining text if any
  if (tolower(line) ~ /^\[(music|applause|laughter)\][[:space:]]*/) {
    sub(/^\[[^]]+\][[:space:]]*/, "", line)
    line = trim(line)
    if (line=="") next
  }

  # Remove consecutive duplicates
  if (line == prev) next
  prev = line

  print line
}
AWK
}

process_all_vtt() {
  while IFS= read -r -d '' vtt; do
    vtt_to_txt "$vtt"
  done < <(find "$TMPDIR" -type f -name "*.vtt" -print0)
}

# ---- main ----
if [[ -f "$INPUT" ]]; then
  # Extract all YouTube URLs from the file, ignoring comments/text
  while IFS= read -r url; do
    [[ -z "$url" ]] && continue
    download_subs "$url"
  done < <(extract_yt_urls "$INPUT")
else
  download_subs "$INPUT"
fi

process_all_vtt
echo "Done. Output: $OUTDIR"
