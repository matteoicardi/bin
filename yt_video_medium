#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<EOF
Usage: $(basename "$0") <youtube_url | file_with_urls>

Downloads YouTube videos in 720p (medium) resolution.

Arguments:
  <youtube_url>       A direct link to a YouTube video or playlist.
  <file_with_urls>    A text file containing one YouTube URL per line.
                      Lines starting with '#' are ignored.

Environment Variables:
  OUTDIR              Directory where videos will be saved.
                      Default: $(pwd)/videos
  ARCHIVE             Path to the download archive file to avoid re-downloads.
                      Default: $OUTDIR/archive.txt
  VIDEO_Q             Quality/Compatibility level:
                        0: Max Compatibility (H.264/AAC). Default.
                           Works in QuickTime, iPhone, and old devices.
                        1: High Efficiency (VP9).
                           Smaller files, better quality, needs VLC/Chrome.
                        2: Ultimate Efficiency (AV1/VP9).
                           Newest codecs, best quality, needs modern VLC.
  FORMAT              Manual yt-dlp format selector (overrides VIDEO_Q).

Output Structure:
  $OUTDIR/<Title>.<ext>

Examples:
  $(basename "$0") "https://www.youtube.com/watch?v=dQw4w9WgXcQ"
  VIDEO_Q=1 $(basename "$0") list.txt
EOF
  exit 0
}

if [[ $# -lt 1 ]] || [[ "$1" == "-h" ]] || [[ "$1" == "--help" ]]; then
  usage
fi

INPUT="$1"
OUTDIR="${OUTDIR:-$(pwd)/videos}"
ARCHIVE="${ARCHIVE:-$OUTDIR/archive.txt}"
VIDEO_Q="${VIDEO_Q:-0}"

mkdir -p "$OUTDIR"

# Select format based on quality level
if [[ -n "${FORMAT:-}" ]]; then
    # Use user-provided format if set
    SELECTED_FORMAT="$FORMAT"
elif [[ "$VIDEO_Q" == "0" ]]; then
    # Level 0: H.264 + AAC (MP4) - Best for Apple/QuickTime
    SELECTED_FORMAT="bestvideo[height<=720][vcodec^=avc1]+bestaudio[acodec^=mp4a]/best[height<=720][vcodec^=avc1]/best"
elif [[ "$VIDEO_Q" == "1" ]]; then
    # Level 1: Prefer VP9, exclude AV1 (MP4/WebM)
    SELECTED_FORMAT="bestvideo[height<=720][vcodec!*=av01]+bestaudio/best[height<=720]/best"
else
    # Level 2: Pure "best" up to 720p (includes AV1)
    SELECTED_FORMAT="bestvideo[height<=720]+bestaudio/best[height<=720]/best"
fi

common_args=(
  --ignore-errors
  --continue
  --no-overwrites
  --retries 10
  --fragment-retries 10
  --concurrent-fragments 4
  --download-archive "$ARCHIVE"
  --add-metadata
  --embed-thumbnail
  --write-thumbnail
  --write-info-json
  --merge-output-format mp4
  --output "$OUTDIR/%(title).200B.%(ext)s"
  -f "$SELECTED_FORMAT"
)


download_one() {
  local url="$1"
  yt-dlp "${common_args[@]}" "$url"
}

# ---- main ----
if [[ -f "$INPUT" ]]; then
  while IFS= read -r url; do
    [[ -z "$url" ]] && continue
    [[ "$url" =~ ^[[:space:]]*# ]] && continue
    download_one "$url"
  done < "$INPUT"
else
  download_one "$INPUT"
fi

echo "Done. Output: $OUTDIR"