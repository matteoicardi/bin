#!/usr/bin/env bash
set -euo pipefail

if [ "$#" -lt 1 ] || [ "$#" -gt 3 ]; then
  echo "Usage: $0 <input.mp4> [output.mp4] [compression_factor]"
  exit 1
fi

INPUT="$1"
OUTPUT="${2:-${INPUT%.*}_smaller.mp4}"
COMPRESSION_FACTOR="${3:-2}"

if ! [[ "$COMPRESSION_FACTOR" =~ ^[0-9]+([.][0-9]+)?$ ]]; then
  echo "Compression factor must be a positive number, got: $COMPRESSION_FACTOR" >&2
  exit 1
fi

python3 - <<'PY' "$COMPRESSION_FACTOR"
import sys
f = float(sys.argv[1])
if f <= 0:
    raise SystemExit(1)
PY

# Read width, height, bitrate from the first video stream
IFS=, read -r WIDTH HEIGHT BITRATE < <(
  ffprobe -v error \
    -select_streams v:0 \
    -show_entries stream=width,height,bit_rate \
    -of csv=p=0 \
    "$INPUT"
)

if [ -z "${WIDTH:-}" ] || [ -z "${HEIGHT:-}" ]; then
  echo "Could not read video dimensions from: $INPUT" >&2
  exit 1
fi

# Some files do not expose stream bit_rate cleanly
if [ -z "${BITRATE:-}" ] || [ "$BITRATE" = "N/A" ]; then
  echo "Could not read video bitrate from stream metadata." >&2
  echo "Falling back to CRF mode instead of target bitrate." >&2

  TARGET_WIDTH=$(python3 - <<'PY' "$WIDTH" "$COMPRESSION_FACTOR"
import math, sys
w = int(sys.argv[1])
f = float(sys.argv[2])
tw = int(round(w / math.sqrt(f)))
if tw % 2:
    tw -= 1
print(max(tw, 2))
PY
)

  ffmpeg -i "$INPUT" \
    -vf "scale=${TARGET_WIDTH}:-2" \
    -c:v libx265 -preset medium -crf 27 \
    -c:a aac -b:a 96k \
    "$OUTPUT"

  exit 0
fi

TARGET_WIDTH=$(python3 - <<'PY' "$WIDTH" "$COMPRESSION_FACTOR"
import math, sys
w = int(sys.argv[1])
f = float(sys.argv[2])
tw = int(round(w / math.sqrt(f)))
if tw % 2:
    tw -= 1
print(max(tw, 2))
PY
)

TARGET_BITRATE=$(python3 - <<'PY' "$BITRATE" "$COMPRESSION_FACTOR"
import sys
bitrate = int(sys.argv[1])
f = float(sys.argv[2])
print(max(int(round(bitrate / f)), 1))
PY
)

echo "Input width:         $WIDTH"
echo "Input height:        $HEIGHT"
echo "Input video bitrate: $BITRATE bps"
echo "Compression factor:  $COMPRESSION_FACTOR"
echo "Target width:        $TARGET_WIDTH"
echo "Target bitrate:      $TARGET_BITRATE bps"

ffmpeg -i "$INPUT" \
  -vf "scale=${TARGET_WIDTH}:-2" \
  -c:v libx265 -b:v "${TARGET_BITRATE}" \
  -c:a aac -b:a 96k \
  "$OUTPUT"